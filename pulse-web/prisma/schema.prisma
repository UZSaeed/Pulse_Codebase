generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id  // Supabase auth.users.id
  email            String            @unique
  name             String?
  image            String?           // Google profile picture
  updatedAt        DateTime          @updatedAt
  subscriptionTier String            @default("FREE")
  dailyStreak      Int               @default(0)
  lastPracticeDate DateTime?
  totalXp          Int               @default(0)
  performances     UserPerformance[]
  calendarState    CalendarState?
  subjectStats     SubjectStats[]
  topicStats       TopicStats[]
  questionFlags    QuestionFlag[]
  questionStates   UserQuestionState[]
  onboardingCompleted Boolean @default(false)
  preferences      UserPreference?
  practiceTests    PracticeTestResult[]
}

model SubjectStats {
  id        String   @id @default(uuid())
  userId    String
  subject   String   // reading_writing, math
  elo       Int      @default(1000)
  xp        Int      @default(0)
  confidence Float   @default(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject])
}

model TopicStats {
  id        String   @id @default(uuid())
  userId    String
  subject   String   // reading_writing, math
  topicName String
  elo       Int      @default(1000)
  xp        Int      @default(0)
  confidence Float   @default(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject, topicName])
}

model Question {
  id            String   @id @default(uuid())
  subject       String
  domain        String?
  skill         String?
  topic         String?
  chapterId     String?
  questionType  String?
  answerFormat  String   @default("multiple_choice")
  difficultyBand String?
  difficultyTier String?
  passage       String?
  text          String   // This can act as the 'stem'
  choices       String?  // JSON string storing choices array
  correctAnswer String?  // e.g., 'A', 'B', 'C', 'D'
  explanation   String
  distractorExplanations String? // JSON string
  baseDifficulty Int     @default(1000)
  tagsJson      Json?
  
  // Sourced Content Metadata
  imageUrls      String?  // JSON array of figure URLs (or imagePrompt for legacy)
  sourcePmcId    String?  // PMC ID for sourced papers
  sourceTitle    String?  // Paper title
  sourceAuthors  String?  // Paper authors
  sourceLicense  String?  // OA license
  requiresFigure Boolean  @default(false)
  referencedFigure String? // e.g., "Figure 1"
  graphSpec      Json?    // function-plot spec rendered client-side by MathGraph
  templateId     String?  // math template that produced this question
  templateSeed   Int?     // RNG seed for deterministic reproduction
  generationType String   @default("hallucinated") // "sourced" | "discrete" | "hallucinated" | "template"
  sourceKind     String   @default("generated") // generated | official_import | official_inspired | user_authored
  sourceReferenceId String?
  sourceReferencePdf String?
  sourceReferencePage Int?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  performances  UserPerformance[]
  flags         QuestionFlag[]
  userStates    UserQuestionState[]
}

model UserPerformance {
  id             String   @id @default(uuid())
  userId         String
  questionId     String
  isCorrect      Boolean
  timeTakenMs    Int?
  eloChange      Int      @default(0)
  srsInterval    Int      @default(0) // SM-2 interval length
  srsRepetitions Int      @default(0)
  srsEaseFactor  Float    @default(2.5)
  nextReviewDate DateTime?
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model UserQuestionState {
  id                  String   @id @default(uuid())
  userId              String
  questionId          String
  firstSeenAt         DateTime @default(now())
  lastSeenAt          DateTime @default(now())
  lastAnsweredAt      DateTime?
  lastAnsweredCorrect Boolean?
  timesSeen           Int      @default(0)
  timesAnswered       Int      @default(0)
  timesCorrect        Int      @default(0)
  nextEligibleAt      DateTime?
  lastDifficultySeen  Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, nextEligibleAt])
}

model CalendarState {
  id           String   @id @default(uuid())
  userId       String   @unique
  accessToken  String
  refreshToken String?
  expiryDate   DateTime?
  mentorPreset String?
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuestionFlag {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  reason     String   // "inaccurate", "poor_visual", "weird_wording", "other"
  details    String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model UserPreference {
  id                         String   @id @default(uuid())
  userId                     String   @unique
  nextTestDate               DateTime?
  preparedByDate             DateTime?
  hasScheduledTest           Boolean  @default(false)
  recentReadingWritingScore  Int?
  recentMathScore            Int?
  confidenceProfile          Json?
  
  // Phase splits (percentages adding up to 100)
  rampUpPercentage           Int      @default(35)
  grindPercentage            Int      @default(45)
  lastStretchPercentage      Int      @default(20)

  // Questions per day targets
  rampUpQuestionsPerDay      Int      @default(16)
  grindQuestionsPerDay       Int      @default(24)
  lastStretchQuestionsPerDay Int      @default(32)

  updatedAt                  DateTime @updatedAt
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PracticeTestResult {
  id                  String   @id @default(uuid())
  userId              String
  takenAt             DateTime @default(now())
  readingWritingScore Int      // section score, 200-800
  mathScore           Int      // section score, 200-800
  domainBreakdown     Json?    // { [chapterId]: { correct: number, total: number } }
  notes               String?
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, takenAt])
}

model Waitlist {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
