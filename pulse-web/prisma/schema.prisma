generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id
  email            String            @unique
  name             String?
  image            String?
  updatedAt        DateTime          @updatedAt
  subscriptionTier String            @default("FREE")
  dailyStreak      Int               @default(0)
  lastPracticeDate DateTime?
  totalXp          Int               @default(0)
  onboardingCompleted Boolean        @default(false)
  performances     UserPerformance[]
  calendarState    CalendarState?
  subjectStats     SubjectStats[]
  topicStats       TopicStats[]
  questionFlags    QuestionFlag[]
  questionStates   UserQuestionState[]
  preferences      UserPreference?
  practiceTests    PracticeTestResult[]
  srsCards         SrsCard[]
}

model SubjectStats {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  elo       Int      @default(1000)
  xp        Int      @default(0)
  confidence Float   @default(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject])
}

model TopicStats {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  topicName String
  elo       Int      @default(1000)
  xp        Int      @default(0)
  confidence Float   @default(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject, topicName])
}

model Question {
  id            String   @id @default(uuid())
  subject       String
  domain        String?
  skill         String?
  topic         String?
  chapterId     String?
  questionType  String?
  answerFormat  String   @default("multiple_choice")
  difficultyBand String?
  difficultyTier String?
  passage       String?
  text          String
  choices       String?
  correctAnswer String?
  explanation   String
  distractorExplanations String?
  baseDifficulty Int     @default(1000)
  tagsJson      Json?

  imageUrls      String?
  sourcePmcId    String?
  sourceTitle    String?
  sourceAuthors  String?
  sourceLicense  String?
  requiresFigure Boolean  @default(false)
  referencedFigure String?
  diagramUrl     String?
  diagramAttribution String?
  hoverDefinitions String?
  seedTermId     String?
  graphSpec      Json?
  templateId     String?
  templateSeed   Int?
  generationType String   @default("hallucinated")
  sourceKind     String   @default("generated")
  sourceReferenceId String?
  sourceReferencePdf String?
  sourceReferencePage Int?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  performances  UserPerformance[]
  flags         QuestionFlag[]
  userStates    UserQuestionState[]
  srsCards      SrsCard[]
}

model SeedTerm {
  id        String    @id @default(uuid())
  front     String
  back      String
  subject   String
  category  String?
  source    String    @default("aamc_outline")
  deckName  String?
  createdAt DateTime  @default(now())
  srsCards  SrsCard[]
}

model SrsCard {
  id             String    @id @default(uuid())
  userId         String
  seedTermId     String
  questionId     String?
  state          String    @default("new")
  interval       Int       @default(0)
  easeFactor     Float     @default(2.5)
  repetitions    Int       @default(0)
  step           Int       @default(0)
  lapses         Int       @default(0)
  dueDate        DateTime  @default(now())
  lastReviewedAt DateTime?
  subject        String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  introducedAt   DateTime?
  question       Question? @relation(fields: [questionId], references: [id])
  seedTerm       SeedTerm  @relation(fields: [seedTermId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, seedTermId])
  @@index([userId, dueDate])
  @@index([userId, subject, state])
}

model UserPerformance {
  id             String   @id @default(uuid())
  userId         String
  questionId     String
  isCorrect      Boolean
  timeTakenMs    Int?
  eloChange      Int      @default(0)
  srsInterval    Int       @default(0)
  srsRepetitions Int       @default(0)
  srsEaseFactor  Float     @default(2.5)
  nextReviewDate DateTime?
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question       Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model UserQuestionState {
  id                  String   @id @default(uuid())
  userId              String
  questionId          String
  firstSeenAt         DateTime @default(now())
  lastSeenAt          DateTime @default(now())
  lastAnsweredAt      DateTime?
  lastAnsweredCorrect Boolean?
  timesSeen           Int      @default(0)
  timesAnswered       Int      @default(0)
  timesCorrect        Int      @default(0)
  nextEligibleAt      DateTime?
  lastDifficultySeen  Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, nextEligibleAt])
}

model CalendarState {
  id           String   @id @default(uuid())
  userId       String   @unique
  accessToken  String
  refreshToken String?
  expiryDate   DateTime?
  mentorPreset String?
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuestionFlag {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  reason     String
  details    String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model UserPreference {
  id                         String   @id @default(uuid())
  userId                     String   @unique
  nextTestDate               DateTime?
  preparedByDate             DateTime?
  hasScheduledTest           Boolean  @default(false)
  recentReadingWritingScore  Int?
  recentMathScore            Int?
  confidenceProfile          Json?
  testDate                   DateTime?

  rampUpPercentage           Int      @default(35)
  grindPercentage            Int      @default(45)
  lastStretchPercentage      Int      @default(20)

  rampUpQuestionsPerDay      Int      @default(16)
  grindQuestionsPerDay       Int      @default(24)
  lastStretchQuestionsPerDay Int      @default(32)

  rampUpNewCardsPerDay       Int      @default(10)
  grindNewCardsPerDay        Int      @default(20)
  lastStretchNewCardsPerDay  Int      @default(15)

  updatedAt                  DateTime @updatedAt
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PracticeTestResult {
  id                  String   @id @default(uuid())
  userId              String
  takenAt             DateTime @default(now())
  readingWritingScore Int
  mathScore           Int
  domainBreakdown     Json?
  notes               String?
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, takenAt])
}

model Waitlist {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
